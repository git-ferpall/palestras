# URL pública do sistema (usada nos QR codes e links de e-mail)
APP_URL=http://localhost:3000
# Produção: APP_URL=https://palestras.abrarastro.org

# Porta do Node (Apache faz proxy para esta porta)
PORT=3000

# Banco de dados SQLite (padrão) — troque por PostgreSQL em produção
DATABASE_URL="file:./dev.db"

# Segredo para sessão do administrador (gere uma string longa e aleatória)
AUTH_SECRET=troque-por-um-segredo-forte-com-pelo-menos-32-caracteres

# Credenciais do administrador inicial (usadas no seed)
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=admin123
ADMIN_NOME=Administrador

# SMTP — envio de certificados (cPanel: mail.abrarastro.org)
# Opção A — porta 465 (SSL):
# SMTP_PORT=465
# SMTP_SECURE=true
# Opção B — se 465 falhar na AWS, use 587 (STARTTLS):
# SMTP_PORT=587
# SMTP_SECURE=false
SMTP_HOST=mail.abrarastro.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=naoresponder@abrarastro.org
SMTP_PASS=senha-da-conta-de-email
SMTP_FROM="Palestras Abrarastro <naoresponder@abrarastro.org>"
# SMTP_TLS_REJECT_UNAUTHORIZED=false
