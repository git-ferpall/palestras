[Unit]
Description=Palestras — Next.js
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/palestras.abrarastro.org
Environment=NODE_ENV=production
Environment=PORT=3000
EnvironmentFile=/var/www/palestras.abrarastro.org/.env
ExecStart=/usr/bin/npm run start -- -p 3000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
